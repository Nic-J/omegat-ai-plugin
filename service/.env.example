# Copy this file to .env and fill in the values you need.
# All settings here are optional — the service runs with sensible defaults
# (Ollama only, no style rules, platform-default state DB) if you set nothing.

# ── API keys ──────────────────────────────────────────────────────────────
# Required only if AI_MODEL (or GLOSSARY_MODEL) uses "anthropic:...".
# ANTHROPIC_API_KEY=

# ── AI model selection ───────────────────────────────────────────────────
# Full PydanticAI model string used for translation.
# Examples: "ollama:mistral-nemo", "anthropic:claude-haiku-4-5-20251001",
#           "google-gla:gemini-2.0-flash"
# AI_MODEL=ollama:mistral-nemo

# Model used for glossary web research (Termium / OQLF lookups).
# Falls back to AI_MODEL if unset. Web research benefits from a stronger
# model — set this to a cloud model while keeping AI_MODEL on local Ollama.
# GLOSSARY_MODEL=

# ── Ollama ────────────────────────────────────────────────────────────────
# Base URL for the local Ollama instance.
# OLLAMA_BASE_URL=http://localhost:11434

# ── File paths ────────────────────────────────────────────────────────────
# Path to a plain-text file of style rules injected into the translation
# prompt. Copy service/style_rules.example.txt, fill in your own rules, and
# point this at an absolute path. Unset by default (no style rules injected).
# STYLE_RULES_PATH=

# Shared SQLite database for glossary + file-summary state. Defaults to a
# platform-appropriate user data dir — only set this to override.
# STATE_DB_PATH=

# ── Glossary agent tuning ─────────────────────────────────────────────────
# Maximum number of candidate terms sent to Termium / OQLF for lookup.
# GLOSSARY_MAX_TERMS=20

# Maximum characters of fetched page text passed to the LLM per tool call.
# GLOSSARY_MAX_PAGE_CHARS=3000
