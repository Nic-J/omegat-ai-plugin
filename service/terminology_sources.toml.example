# Terminology lookup sources — live HTTP fetch (optional extension).
#
# NOTE: Termium and OQLF are no longer fetched live. Both are bot-blocked:
#   - OQLF: AWS WAF JS challenge (HTTP 202, empty body)
#   - Termium: timeout for non-browser clients
#
# Instead, import their open-data CSV exports once into the local index:
#   uv run python -m glossary.cli import-terminology <file> --preset termium
#   uv run python -m glossary.cli import-terminology <file> --preset oqlf
#
# This file is for adding your OWN live HTTP/API sources on top of the local index.
# Copy to terminology_sources.toml (next to .env). Entries here become additional
# tools the glossary agent can call alongside lookup_terminology.
#
# Fields:
#   name          - used to build the tool name (fetch_<name>)
#   enabled       - set false to disable without deleting the entry
#   description   - shown to the LLM so it knows what the source covers
#   url_template  - "{term}" is substituted; "{lang}" if lang_map matches
#   lang_map      - optional source_lang prefix -> {lang} substitution

# Example: EU multilingual terminology (IATE)
[[sources]]
name = "iate"
enabled = false
description = "EU multilingual terminology"
url_template = "https://iate.europa.eu/search#/result/1/1/{term}/1/1/0/none"

# Example: Microsoft software localization terminology
[[sources]]
name = "microsoft_terminology"
enabled = false
description = "Microsoft software localization terminology"
url_template = "https://www.microsoft.com/en-us/language/Search?text={term}"
